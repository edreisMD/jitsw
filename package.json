{
  "name": "jitsw",
  "version": "0.0.1",
  "private": true,
  "description": "JITSW — the mobile A2UI client for GBrain-native agents",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "wire": "./scripts/wire-openclaw.sh",
    "tunnel": "ngrok start --config infra/ngrok/ngrok.yml --all",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0"
}
