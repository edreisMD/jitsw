# JITSW environment variables.
# Copy to .env and fill in. Anything unset disables that subsystem.

# ---- API server -----------------------------------------------------------
PORT=8787

# ---- Authentication -------------------------------------------------------
# AUTH_MODE controls how the API authenticates callers.
#   none      No auth (DEV ONLY). Sets a synthetic "local-dev" principal.
#   firebase  Verify Firebase ID tokens via firebase-admin.
#   api-keys  Static bearer keys for agents (JSON array, see below).
AUTH_MODE=none
# Set to "false" to allow anonymous requests even when AUTH_MODE != none.
# AUTH_REQUIRED=true

# Firebase mode:
# FIREBASE_PROJECT_ID=your-project
# GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa.json
# AUTH_ALLOWED_DOMAINS=acme.com,example.org

# api-keys mode:
# AGENT_KEYS='[{"key":"k_xxx","agentId":"openclaw:demo","scopes":["packets:write"]}]'

# ---- Persistent store -----------------------------------------------------
# Postgres connection string. If unset, the API uses an in-memory store
# (fine for tests and the simplest local dev, lost on restart).
DATABASE_URL=postgres://jitsw:jitsw@localhost:5433/jitsw

# ---- Matrix bridge --------------------------------------------------------
# When all three are set, the API logs into Matrix and converts events with
# `com.jitsw.a2ui` content into Packets.
MATRIX_HOMESERVER_URL=
MATRIX_ACCESS_TOKEN=
MATRIX_USER_ID=
# Optional comma-separated list of room IDs to filter on.
MATRIX_ROOMS=

# ---- GBrain sync ----------------------------------------------------------
# When GBRAIN_HTTP_URL is set, every packet/action is written to GBrain.
GBRAIN_HTTP_URL=
GBRAIN_BEARER_TOKEN=
GBRAIN_SOURCE=jitsw
